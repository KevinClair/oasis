# Copy this file to .env and fill in your values before running docker compose

# MySQL credentials
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=oasis
MYSQL_PASSWORD=change_me_oasis_password

# Domain name (used in nginx SSL config)
DOMAIN=yourdomain.com

# Docker image overrides (set by CI/CD pipeline automatically)
# BACKEND_IMAGE=ghcr.io/kevinclair/oasis/oasis-admin:latest
# FRONTEND_IMAGE=ghcr.io/kevinclair/oasis/oasis-web:latest
